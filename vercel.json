{
  "version": 2,
  "rewrites": [
    { "source": "/api/plan-current", "destination": "/api/plan?__route=plan-current" },
    { "source": "/api/plan-features", "destination": "/api/plan?__route=plan-features" },
    { "source": "/api/config", "destination": "/api/plan?__route=config" },
    { "source": "/api/affiliate-referral", "destination": "/api/affiliate?__route=affiliate-referral" },
    { "source": "/api/affiliate-commissions", "destination": "/api/affiliate?__route=affiliate-commissions" },
    { "source": "/api/science-articles", "destination": "/api/system?__route=science-articles" },
    { "source": "/api/science-review", "destination": "/api/system?__route=science-review" },
    { "source": "/api/science-sync", "destination": "/api/system?__route=science-sync" },
    { "source": "/api/lgpd-export", "destination": "/api/system?__route=lgpd-export" },
    { "source": "/api/lgpd-delete", "destination": "/api/system?__route=lgpd-delete" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/pastor-diagnostico",
      "schedule": "0 3 * * *"
    }
  ]
}
