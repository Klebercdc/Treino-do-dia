{
  "name": "kronia",
  "version": "1.0.0",
  "private": true,
  "description": "KRONIA — Sistema de Gestão Fisiológica e Periodização",
  "scripts": {
    "test:e2e": "npm run db:push:test && playwright test",
    "test:sanity": "playwright test tests/e2e/sanity.spec.ts --reporter=list",
    "test:workout": "playwright test tests/e2e/workout-registration.spec.ts --reporter=list",
    "db:pull": "supabase db pull",
    "db:push:test": "dotenv -e .env.test -- supabase db push --db-url \"$VITE_SUPABASE_DB_URL_TEST\"",
    "serve": "npx serve . -p 3000 --no-clipboard",
    "scraper": "node etl/scrapers/cli.js",
    "scraper:wger": "node etl/scrapers/cli.js --sources wger --stats",
    "scraper:exrx": "node etl/scrapers/cli.js --sources exrx --stats",
    "scraper:all": "node etl/scrapers/cli.js --sources wger,exrx --csv --stats",
    "system:check": "sh -c 'if command -v tsx >/dev/null 2>&1; then tsx scripts/system-check.ts; else npm run -s system:check:legacy; fi'",
    "system:check:legacy": "tsc --pretty false --target ES2020 --module node16 --moduleResolution node16 --lib ES2020,DOM --types node --esModuleInterop --skipLibCheck --outDir .tmp-system-check scripts/system-check.ts src/lib/checks/*.ts src/lib/utils/env.ts && node .tmp-system-check/scripts/system-check.js",
    "test:access": "node scripts/test-access.js",
    "migrate": "tsx scripts/run-migrations.ts",
    "migrate:dry": "tsx scripts/run-migrations.ts --dry-run",
    "seed:exercises": "tsx scripts/seed-exercises.ts",
    "review:exercise-media": "tsx scripts/review-exercise-media-cache.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/node": "^20.19.37",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "serve": "^14.2.3",
    "tsx": "^4.20.0",
    "typescript": "^5.4.5"
  }
}
