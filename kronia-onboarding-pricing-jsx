// ─── APP PRINCIPAL ────────────────────────────────────────────────────────────
export default function KroniaApp() {
const [screen, setScreen] = useState(“onboarding”);
const [userPlan, setUserPlan] = useState(“free”);

function handleSelectPlan(id) {
if (id!==“free”) setUserPlan(id);
setScreen(“home”);
}

if (screen===“onboarding”) return <OnboardingCarousel onFinish={()=>setScreen(“auth”)}/>;
if (screen===“auth”)       return <AuthScreen onAuth={()=>setScreen(“home”)}/>;
if (screen===“pricing”)    return <PricingPage currentPlan={userPlan} onSelect={handleSelectPlan}/>;
return <HomePage userPlan={userPlan} onUpgrade={()=>setScreen(“pricing”)}/>;
}
