// ─── ONBOARDING CAROUSEL ──────────────────────────────────────────────────────
function OnboardingCarousel({ onFinish }) {
const [current, setCurrent] = useState(0);
const [dir, setDir] = useState(1);
const [anim, setAnim] = useState(false);
const touch = useRef(null);

function goTo(idx) {
if (anim || idx===current) return;
setDir(idx>current?1:-1); setAnim(true);
setTimeout(()=>{ setCurrent(idx); setAnim(false); }, 260);
}
function next() { if(current<SLIDES.length-1) goTo(current+1); else onFinish(); }

const slide = SLIDES[current];

return (
<div style={{
minHeight:“100vh”, background:”#090909”,
display:“flex”, flexDirection:“column”,
fontFamily:”‘Barlow Condensed’,‘Barlow’,sans-serif”,
overflow:“hidden”, position:“relative”,
}}>
<div style={{ position:“absolute”, inset:0, background:slide.bg, transition:“background 0.5s”, pointerEvents:“none” }}/>
<div style={{
position:“absolute”, inset:0, pointerEvents:“none”,
backgroundImage:“linear-gradient(rgba(255,107,0,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,107,0,0.025) 1px,transparent 1px)”,
backgroundSize:“32px 32px”,
}}/>

